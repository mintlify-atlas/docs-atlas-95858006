  "keyFeatures": [
    "Zero-copy, thread-safe BTreeMap-based API",
    "Fully ACID-compliant transactions",
    "MVCC for concurrent readers and a single writer without blocking",
    "Crash-safe by default using checksummed copy-on-write B-trees",
    "Savepoints and rollbacks (ephemeral and persistent)",
    "Pluggable storage backends (file and in-memory built-in)",
    "Multimap tables supporting multiple values per key",
    "Optional logging and cache metrics features",
    "Pure Rust with no unsafe dependencies",
    "Stable file format with upgrade path guarantees"
  ],
